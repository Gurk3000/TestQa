# Copy this file to credentials.env and fill in real values.
# The real credentials.env file is gitignored.

TESTRAIL_BASE_URL=https://your-instance.testrail.io
TESTRAIL_EMAIL=your_email@example.com
TESTRAIL_PASSWORD=your_password
TESTRAIL_API_KEY=

TESTRAIL_PROJECT_NAME=Your Project Name
TESTRAIL_PROJECT_ID=
TESTRAIL_SUITE_ID=
TESTRAIL_SECTION_ID=

BROWSER=chrome
HEADLESS=false
IMPLICIT_WAIT=0
EXPLICIT_WAIT=20
PAGE_LOAD_TIMEOUT=40
UI_RETRY_COUNT=2
TESTRAIL_SCREENSHOT_ON_SUCCESS=true
# TESTRAIL_ALLURE_OPEN=false
