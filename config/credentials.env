# TestRail credentials and environment configuration
# Copy / fill real values. Do NOT commit real secrets to VCS.

# Base URL of the TestRail instance (no trailing slash)
TESTRAIL_BASE_URL=https://testtask.testrail-staging.com

# UI / API login credentials
TESTRAIL_EMAIL=yuriy.valchenko@gmail.com
TESTRAIL_PASSWORD=Test2026!

# Optional dedicated API key (TestRail > My Settings > API Keys).
# If empty, the password above is used for API Basic Auth.
TESTRAIL_API_KEY=

# Target project name exactly as displayed in TestRail
TESTRAIL_PROJECT_NAME=Yurii Test Project

# Optional explicit IDs (auto-resolved via API if left empty)
TESTRAIL_PROJECT_ID=
TESTRAIL_SUITE_ID=
TESTRAIL_SECTION_ID=

# Browser settings: chrome | firefox | edge
BROWSER=chrome
HEADLESS=false
IMPLICIT_WAIT=0
EXPLICIT_WAIT=20
PAGE_LOAD_TIMEOUT=40

# Stability: number of UI retries for flaky tests
UI_RETRY_COUNT=2

# Reporting: also capture/attach a screenshot for PASSED tests (true|false).
# Set to false to capture screenshots only on failure (faster large runs).
TESTRAIL_SCREENSHOT_ON_SUCCESS=true

# After Allure mode: auto-open static report in browser (allure open). Skipped in CI.
# Uncomment to disable locally: TESTRAIL_ALLURE_OPEN=false
